# Identity configuration for the platform. Copy to .streamlit/secrets.toml and
# fill in your own values. NEVER commit the real secrets.toml (it is gitignored).
#
# Two sections:
#   [auth.*]   Streamlit-native OpenID Connect (the OAuth2 flow, via Authlib)
#   [identity] the platform's access policy (who gets in, and as what role)
#
# No tenant ids or domains are hard-coded anywhere in the code - they live only
# here.

# ----------------------------------------------------------------------------
# Streamlit native authentication (https://docs.streamlit.io -> st.login)
# ----------------------------------------------------------------------------
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"   # your deployed URL + /oauth2callback
cookie_secret = "change-me-to-a-long-random-string"

# --- Microsoft Entra ID (Azure AD / Microsoft 365) --------------------------
# Register an app in Entra; put the Application (client) ID and a client secret
# here, and your tenant id in the metadata URL.
[auth.microsoft]
client_id = "YOUR-ENTRA-APPLICATION-CLIENT-ID"
client_secret = "YOUR-ENTRA-CLIENT-SECRET"
server_metadata_url = "https://login.microsoftonline.com/YOUR-TENANT-ID/v2.0/.well-known/openid-configuration"

# --- Other providers (uncomment the one you use) ----------------------------
# [auth.google]
# client_id = "..."
# client_secret = "..."
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
#
# [auth.okta]
# client_id = "..."
# client_secret = "..."
# server_metadata_url = "https://YOUR-DOMAIN.okta.com/.well-known/openid-configuration"
#
# [auth.auth0]
# client_id = "..."
# client_secret = "..."
# server_metadata_url = "https://YOUR-TENANT.us.auth0.com/.well-known/openid-configuration"
#
# [auth.keycloak]
# client_id = "..."
# client_secret = "..."
# server_metadata_url = "https://YOUR-HOST/realms/YOUR-REALM/.well-known/openid-configuration"

# ----------------------------------------------------------------------------
# Platform access policy (authorization). Fail closed: with neither
# allowed_domains nor email_whitelist, NO ONE is admitted.
# ----------------------------------------------------------------------------
[identity]
providers = ["microsoft"]              # sign-in options offered, in order
allowed_domains = ["yourclub.com"]     # everyone at these domains may sign in
email_whitelist = []                   # extra individual emails, any domain
default_role = "read_only"             # role for an admitted user with no assignment
fail_closed = true
session_timeout_minutes = 480          # idle timeout; 0 disables
remember_session = false               # true keeps a session alive across the idle window
organization = "Your Club FC"

# email -> role (highest-priority role source). Roles: super_admin, club_admin,
# head_coach, assistant_coach, goalkeeper_coach, performance_analyst,
# first_team_analyst, academy_analyst, recruitment_analyst, scout,
# medical_staff, read_only.
[identity.role_assignments]
"sporting.director@yourclub.com" = "club_admin"
"head.analyst@yourclub.com" = "performance_analyst"

# provider group / app-role name -> platform role (used when no per-email
# assignment matches). For Entra, emit app roles or groups as a claim.
[identity.group_roles]
"First Team Analysts" = "first_team_analyst"
"Academy" = "academy_analyst"
